{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "make ci-suite"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(gh api repos/mythrnr/wmf-rs/pulls/*/comments)",
      "Bash(gh api repos/mythrnr/wmf-rs/pulls/*/reviews)",
      "Bash(gh pr view *)",
      "Bash(make check)",
      "Bash(make clean)",
      "Bash(make fix)",
      "Bash(make fmt)",
      "Bash(make lint)",
      "Bash(make spell-check)",
      "Bash(make test)",
      "Bash(make udeps)",
      "Bash(make wasm)"
    ],
    "deny": [
      "Bash(make release *)"
    ]
  }
}
